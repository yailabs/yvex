#!/usr/bin/env sh
set -eu

log_path=${YVEX_FAKE_HF_LOG:-build/tests/fake-hf.log}
mkdir -p "$(dirname "$log_path")"

{
  printf 'fake-hf argv:\n'
  redact_next=0
  for arg in "$@"; do
    if [ "$redact_next" -eq 1 ]; then
      printf '  <redacted>\n'
      redact_next=0
      continue
    fi
    printf '  %s\n' "$arg"
    if [ "$arg" = "--token" ]; then
      redact_next=1
    fi
  done
} >> "$log_path"

if [ "${YVEX_FAKE_HF_FAIL:-0}" = "1" ]; then
  printf 'fake-hf: requested failure\n' >&2
  exit 42
fi

if [ "$#" -lt 2 ] || [ "$1" != "download" ]; then
  printf 'fake-hf: expected download REPO\n' >&2
  exit 2
fi

repo=$2
shift 2
local_dir=
dry_run=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --local-dir)
      [ "$#" -ge 2 ] || exit 2
      local_dir=$2
      shift 2
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --revision|--include|--exclude|--max-workers|--token)
      [ "$#" -ge 2 ] || exit 2
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ "$dry_run" -eq 1 ]; then
  printf 'fake-hf: dry-run repo=%s local_dir=%s\n' "$repo" "$local_dir"
  exit 0
fi

if [ -z "$local_dir" ]; then
  printf 'fake-hf: --local-dir is required\n' >&2
  exit 2
fi

mkdir -p "$local_dir"
step_delay=${YVEX_FAKE_HF_STEP_DELAY:-0}
steps=${YVEX_FAKE_HF_STEPS:-3}
fail_at=${YVEX_FAKE_HF_FAIL_AT_STEP:-0}

fake_hf_step() {
  step=$1
  if [ "$fail_at" = "$step" ]; then
    printf 'fake-hf: failing at step %s\n' "$step" >&2
    exit 43
  fi
  if [ "$step_delay" != "0" ]; then
    sleep "$step_delay"
  fi
}

fake_hf_write_shard() {
  python3 - "$1" "$2" "$3" <<'PY'
import json
import struct
import sys

path = sys.argv[1]
name = sys.argv[2]
payload_len = int(sys.argv[3])
header = {
    "__metadata__": {"format": "pt"},
    name: {
        "dtype": "F16",
        "shape": [2, max(1, payload_len // 4)],
        "data_offsets": [0, payload_len],
    },
}
blob = json.dumps(header, separators=(",", ":")).encode("utf-8")
with open(path, "wb") as f:
    f.write(struct.pack("<Q", len(blob)))
    f.write(blob)
    f.write(bytes(payload_len))
PY
}

printf 'fake-hf: resolving repo\n'
printf 'fake-hf: stderr resolving repo\n' >&2
printf '{}\n' > "$local_dir/config.json"
printf '{}\n' > "$local_dir/tokenizer.json"
printf '{}\n' > "$local_dir/tokenizer_config.json"
printf '# fake model card\n' > "$local_dir/README.md"
fake_hf_step 1

printf 'fake-hf: downloading shard 1\n'
fake_hf_write_shard "$local_dir/model-00001-of-00002.safetensors" "embed.weight" 16
fake_hf_step 2

printf 'fake-hf: downloading shard 2\n'
fake_hf_write_shard "$local_dir/model-00002-of-00002.safetensors" "layers.0.attn.q_proj.weight" 32
fake_hf_step 3

i=4
while [ "$i" -le "$steps" ]; do
  printf 'fake-hf: verifying step %s\n' "$i"
  fake_hf_step "$i"
  i=$((i + 1))
done

printf 'fake-hf: complete\n'
printf 'fake-hf: downloaded repo=%s local_dir=%s\n' "$repo" "$local_dir"
