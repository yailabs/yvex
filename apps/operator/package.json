{
  "name": "@yvex/operator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,blue \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build && tsup --config tsup.config.ts",
    "start": "node dist/operator-server.js",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run --maxWorkers=2",
    "test:unit": "vitest run tests/unit --maxWorkers=2",
    "test:adapter": "vitest run tests/adapter --maxWorkers=2",
    "test:component": "vitest run tests/component --maxWorkers=2",
    "test:browser": "nice -n 10 playwright test --workers=1",
    "screenshots": "node scripts/capture-operator-screenshots.mjs",
    "lock:verify": "node scripts/verify-lock.mjs",
    "scan": "node scripts/scan-worktree.mjs",
    "validate": "npm run lock:verify && npm run format && npm run lint && npm run typecheck && npm test && npm run build && npm run test:browser && npm run scan"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
